{
  "name": "ix-puppeteer-dashboard",
  "version": "1.0.0",
  "description": "Dashboard de automação ixBrowser com Puppeteer e Socket.io",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "src/"
    ],
    "ext": "js,json",
    "ignore": [
      "public/",
      "node_modules/"
    ],
    "delay": 500
  },
  "dependencies": {
    "axios": "^1.7.2",
    "better-sqlite3": "^12.8.0",
    "express": "^4.19.2",
    "puppeteer-core": "^22.11.0",
    "socket.io": "^4.7.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
